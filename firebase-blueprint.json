{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with body stats and authorization credentials.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "passwordHash": { "type": "string" },
        "age": { "type": "number" },
        "gender": { "type": "string" },
        "height": { "type": "number" },
        "weight": { "type": "number" },
        "activityLevel": { "type": "string" },
        "role": { "type": "string" }
      },
      "required": ["name", "email", "passwordHash"]
    },
    "Meal": {
      "title": "Meal",
      "description": "Logged food meal item with details and estimated macronutrient values.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "mealName": { "type": "string" },
        "description": { "type": "string" },
        "calories": { "type": "number" },
        "protein": { "type": "number" },
        "carbs": { "type": "number" },
        "fat": { "type": "number" },
        "date": { "type": "string" }
      },
      "required": ["userId", "mealName", "calories"]
    },
    "Suggestion": {
      "title": "Suggestion",
      "description": "AI-generated customized nutrition advice, timing, exercises, and target calorie intake.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "age": { "type": "number" },
        "height": { "type": "number" },
        "weight": { "type": "number" },
        "bmi": { "type": "number" },
        "suggestion": { "type": "string" },
        "timing": { "type": "string" },
        "walk": { "type": "string" },
        "calorieIntake": { "type": "number" },
        "carbohydrateNeeds": { "type": "number" },
        "proteinNeeds": { "type": "number" },
        "weightGain": { "type": "string" },
        "date": { "type": "string" }
      },
      "required": ["userId", "userName", "suggestion"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles indexed by ID"
    },
    "meals/{mealId}": {
      "schema": "Meal",
      "description": "Logged meals by users"
    },
    "suggestions/{suggestionId}": {
      "schema": "Suggestion",
      "description": "Nutritional recommendations generated by the AI assistant"
    }
  }
}
